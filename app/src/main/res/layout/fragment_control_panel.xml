<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="40dp"
        android:paddingBottom="40dp">

        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center_horizontal">

            <!-- Grey Outer Track -->
            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_gauge_track"/>

            <!-- Yellow Active Ring -->
            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_gauge_active"/>

            <!-- White Center -->
            <View
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_inner_white"/>

            <!-- Temperature Text -->
            <TextView
                android:id="@+id/dialTempText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#444444"
                android:layout_gravity="center"/>

        </FrameLayout>

        <TextView
            android:id="@+id/setpointStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/mlPredictionLabel"
            android:text="ML Prediction"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>


        <TextView
            android:id="@+id/mlPredictionValue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- +/- Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/icon_minus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/icon_minus"/>

            <TextView
                android:id="@+id/pendingSetpointText"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:text=""/>

            <ImageView
                android:id="@+id/icon_plus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/icon_add"/>
        </LinearLayout>

        <!-- Device ID -->
        <TextView
            android:id="@+id/deviceIdText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device ID: --"
            android:layout_marginTop="12dp"/>

        <!-- Room Temperature Card -->
        <LinearLayout
            android:layout_width="250dp"
            android:layout_height="82dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_info_card"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:text="Room Temperature"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/currentTempValue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Airflow Card -->
        <LinearLayout
            android:layout_width="250dp"
            android:layout_height="82dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_info_card"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:text="Airflow"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/airflowValue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>