<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Device ID / Mode row -->
        <TextView
            android:id="@+id/deviceIdText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Device ID: --"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ── Dial ── -->
        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp">

            <!-- Grey track ring -->
            <View
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_gauge_track" />

            <!-- Yellow active ring -->
            <View
                android:layout_width="216dp"
                android:layout_height="216dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_gauge_active" />

            <!-- White center -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_inner_white" />

            <!-- Setpoint temp -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/dialTempText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETPOINT"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:textColor="#BBBBBB" />
            </LinearLayout>
        </FrameLayout>

        <!-- Status text (sent / confirmed) -->
        <TextView
            android:id="@+id/setpointStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <!-- ── +/- Stepper ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/icon_minus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/icon_minus"
                android:background="@drawable/bg_step_btn"
                android:padding="10dp" />

            <TextView
                android:id="@+id/pendingSetpointText"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FBC30E"
                android:text="" />

            <ImageView
                android:id="@+id/icon_plus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/icon_add"
                android:background="@drawable/bg_step_btn"
                android:padding="10dp" />
        </LinearLayout>

        <!-- ── Section label ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIVE READINGS"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#AAAAAA"
            android:paddingTop="16dp"
            android:paddingBottom="10dp" />

        <!-- ── 2×1 sensor grid (only Room Temp + Airflow) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Room Temperature card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_chart_card"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <LinearLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_icon_amber"
                    android:gravity="center"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_thermometer"
                        android:contentDescription="temperature" />
                </LinearLayout>

                <TextView
                    android:id="@+id/currentTempValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Room temperature"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Airflow card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_chart_card"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <LinearLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_icon_blue"
                    android:gravity="center"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_airflow"
                        android:contentDescription="airflow" />
                </LinearLayout>

                <TextView
                    android:id="@+id/airflowValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Airflow (CFM)"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>