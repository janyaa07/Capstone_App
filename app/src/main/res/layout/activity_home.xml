<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ── Top Bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo — bigger, no yellow background -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="Aire-Venture logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="AIRE-VENTURE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="#AAAAAA" />

        <!-- Connection badge -->
        <LinearLayout
            android:id="@+id/connectionBadge"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_conn_badge"
            android:layout_marginEnd="8dp">

            <View
                android:id="@+id/connDot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_live_dot"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/connLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wi-Fi"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#444444" />
        </LinearLayout>

        <!-- Settings icon button -->
        <LinearLayout
            android:id="@+id/settingsIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_btn"
            android:gravity="center">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/settings"
                android:contentDescription="Settings" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Panel Container ── -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/panelContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Bottom Tabs ── -->
    <LinearLayout
        android:id="@+id/bottomTabs"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/controlTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Active indicator bar (shown/hidden in code) -->
            <View
                android:id="@+id/controlTabIndicator"
                android:layout_width="28dp"
                android:layout_height="2dp"
                android:background="#FBC30E"
                android:layout_marginBottom="6dp"/>

            <ImageView
                android:id="@+id/controlTabIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/controlpanel" />

            <TextView
                android:id="@+id/controlTabLabel"
                android:text="Control panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:textColor="#B8930A" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dataTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <View
                android:id="@+id/dataTabIndicator"
                android:layout_width="28dp"
                android:layout_height="2dp"
                android:background="@android:color/transparent"
                android:layout_marginBottom="6dp"/>

            <ImageView
                android:id="@+id/dataTabIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/datapanel" />

            <TextView
                android:id="@+id/dataTabLabel"
                android:text="Data panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:textColor="#AAAAAA" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Settings Dropdown Menu ── -->
    <LinearLayout
        android:id="@+id/settingsMenu"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:visibility="gone"
        android:elevation="12dp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp">

        <Button
            android:id="@+id/WifiBluetoothButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Pairing mode"
            android:backgroundTint="#FBC30E"
            android:textColor="@android:color/black"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/SignOut"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Sign out"
            android:backgroundTint="#FBC30E"
            android:textColor="@android:color/black"
            android:textAllCaps="false"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>